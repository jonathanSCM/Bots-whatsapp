# --- WhatsApp Cloud API ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=cambia_este_token_de_verificacion

# --- OpenAI ---
OPENAI_API_KEY=

# --- Google ---
# GOOGLE_SHEET_ID: solo se usa para el bot Restaurante (pestaña Menu) y para
# la hoja compartida "Leads" de negocios interesados en tener su propio bot.
# Las propiedades del bot Inmobiliario ya NO viven en Sheets, se cargan
# desde el backoffice (/admin) y se guardan en SQLite.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=
# GOOGLE_CALENDAR_ID: calendario real donde se crean las citas de Inmobiliaria.
GOOGLE_CALENDAR_ID=

# --- Backoffice (panel de leads y visitas) ---
ADMIN_USER=admin
ADMIN_PASS=cambia_esta_clave

# --- Servidor ---
PORT=3000
